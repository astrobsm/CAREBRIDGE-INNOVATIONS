# Family App frontend — runtime config
# All vars MUST start with REACT_APP_ for CRA to expose them at build time.

# Backend API base URL (Express). Defaults to "/api" + CRA proxy.
REACT_APP_API_URL=

# Supabase Realtime — REQUIRED for cross-device live sync.
# Get these from Supabase Dashboard -> Project Settings -> API.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
