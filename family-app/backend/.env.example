# Database (Local Postgres OR Supabase pooler)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=family_app
DB_USER=postgres
DB_PASSWORD=your_password_here

# Optional: when running against Supabase set
#   DB_HOST=aws-0-<region>.pooler.supabase.com
#   DB_PORT=6543
#   DB_NAME=postgres
#   DB_USER=postgres.<project-ref>
#   DB_PASSWORD=<your supabase db password>
#   DB_SSL=true
# AstroHEALTH integration pins every connection to this schema
DB_SCHEMA=family
DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS) — include the AstroHEALTH origin so the iframe works
CLIENT_URL=http://localhost:3000,http://localhost:3001
