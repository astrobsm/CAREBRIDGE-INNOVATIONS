# CareBridge Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Get from https://supabase.com/dashboard)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Sync API URL (if using custom backend)
VITE_SYNC_API_URL=

# ── OCR / AI Vision API Keys (all optional — Tesseract.js works offline without any keys) ──

# Google Cloud Vision API (primary cloud OCR engine)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_VISION_API_KEY=

# Azure Computer Vision (secondary/fallback OCR engine)
# Get from: https://portal.azure.com → Cognitive Services → Computer Vision
VITE_AZURE_CV_ENDPOINT=
VITE_AZURE_CV_KEY=

# OpenAI GPT-4 Vision (handwriting recognition fallback)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
